    "ai":      { "base": "#8B5CF6", "soft": "#EDE9FE", "dark": "#5B21B6" }
  },
  "font": {
    "display": "\"Space Grotesk\", \"Inter\", -apple-system, system-ui, sans-serif",
    "text": "\"Inter\", -apple-system, system-ui, sans-serif",
    "mono": "\"JetBrains Mono\", ui-monospace, Menlo, monospace"
  },
  "typeScale": {
    "mobile": {
      "displayXl": { "size": 32, "lineHeight": 36, "weight": 700, "font": "display" },
      "displayL":  { "size": 24, "lineHeight": 30, "weight": 700, "font": "display" },
      "displayM":  { "size": 20, "lineHeight": 26, "weight": 600, "font": "display" },
      "titleL":    { "size": 18, "lineHeight": 24, "weight": 600, "font": "text" },
      "titleM":    { "size": 16, "lineHeight": 22, "weight": 600, "font": "text" },
      "bodyL":     { "size": 16, "lineHeight": 22, "weight": 400, "font": "text" },
      "bodyM":     { "size": 14, "lineHeight": 20, "weight": 400, "font": "text" },
      "bodyS":     { "size": 12, "lineHeight": 16, "weight": 400, "font": "text" },
      "label":     { "size": 11, "lineHeight": 14, "weight": 600, "font": "text" },
      "tag":       { "size": 10, "lineHeight": 14, "weight": 600, "font": "mono", "letterSpacing": 0.08, "uppercase": true }
    },
    "web": {
      "hero":       { "size": 64, "lineHeight": 1.05, "weight": 700, "font": "display", "letterSpacing": -0.035 },
      "displayL":   { "size": 40, "lineHeight": 1.1,  "weight": 700, "font": "display", "letterSpacing": -0.025 },
      "displayM":   { "size": 28, "lineHeight": 1.2,  "weight": 700, "font": "display" },
      "titleL":     { "size": 20, "lineHeight": 28,   "weight": 600, "font": "text" },
      "titleM":     { "size": 16, "lineHeight": 22,   "weight": 600, "font": "text" },
      "bodyL":      { "size": 16, "lineHeight": 24,   "weight": 400, "font": "text" },
      "bodyM":      { "size": 14, "lineHeight": 20,   "weight": 400, "font": "text" },
      "tableCell":  { "size": 12, "lineHeight": 16,   "weight": 400, "font": "text" },
      "tableHeader":{ "size": 10, "lineHeight": 14,   "weight": 600, "font": "text", "letterSpacing": 0.05, "uppercase": true }
    }
  },
  "space": { "0":0,"1":4,"2":8,"3":12,"4":16,"5":20,"6":24,"8":32,"10":40,"12":48,"16":64,"20":80 },
  "radius": { "xs":3,"s":6,"m":8,"l":12,"xl":14,"2xl":16,"3xl":24,"full":999 },
  "shadow": {
    "1": "0 1px 2px rgba(0,0,0,0.06)",
    "2": "0 4px 8px rgba(0,0,0,0.08)",
    "3": "0 8px 20px rgba(0,0,0,0.10)",
    "4": "0 16px 40px rgba(0,0,0,0.15)",
    "5": "0 30px 80px rgba(10,10,30,0.28)"
