    "fast":   { "duration": 120,  "easing": "cubic-bezier(0.2,0,0,1)" },
    "base":   { "duration": 200,  "easing": "cubic-bezier(0.2,0,0,1)" },
    "slow":   { "duration": 320,  "easing": "cubic-bezier(0.4,0,0.2,1)" },
    "beacon": { "duration": 1600, "easing": "ease-out", "iterationCount": "infinite" }
  },
  "breakpoint": { "sm":640,"md":768,"lg":1024,"xl":1280,"2xl":1536 }
