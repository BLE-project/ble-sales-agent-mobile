{
  "$comment": "Terrio design tokens — machine-readable. Colors under 'brand' are WHITE-LABEL placeholders (defaults). See tokens/colors-white-label.md.",
  "version": "1.0.0",
  "brand": {
    "$note": "WHITE-LABEL — runtime-configurable per tenant. Fetched from GET /v1/tenants/{id}/branding. These are the Terrio defaults / fallback.",
    "primary": "#5E30C9",
    "primaryDeep": "#3A1A7E",
    "primarySoft": "#EEE6FF",
    "accent": "#FFD83D"
  },
  "neutral": {
    "black": "#0B0B12",
    "monoInk": "#0F172A",
    "gray900": "#111827",
    "gray700": "#374151",
    "gray500": "#6B7280",
    "gray400": "#9CA3AF",
    "gray300": "#D1D5DB",
    "gray200": "#E5E7EB",
    "gray100": "#F3F4F6",
    "gray50": "#F9FAFB",
    "whiteWarm": "#FAF9F6",
    "white": "#FFFFFF"
  },
  "semantic": {
    "success": { "base": "#10B981", "soft": "#D1FAE5", "dark": "#065F46" },
    "warning": { "base": "#F59E0B", "soft": "#FEF3C7", "dark": "#92400E" },
    "danger":  { "base": "#EF4444", "soft": "#FEE2E2", "dark": "#991B1B" },
