{
  "expo": {
    "name": "Terrio Sales Agent",
    "slug": "terrio-sales-agent-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "terrio-sales-agent",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a3f6f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.terrio.salesagent",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Terrio Sales Agent uses Face ID to unlock the app without re-typing your password."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a3f6f"
      },
      "package": "com.terrio.salesagent",
      "usesCleartextTraffic": true,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Terrio Sales Agent uses Face ID to unlock the app without re-typing your password."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1a3f6f"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "networkSecurityConfig": "./network_security_config.xml"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8bbc65ac-eab7-42b4-9686-17a25bbab628"
      }
    },
    "owner": "jdterrio_expo"
  }
}
