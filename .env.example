# BLE Sales Agent Mobile — environment variables
# Copy to .env.local and adjust for your setup.

# API Gateway (BFF) base URL — used by client.ts and AuthContext for all API calls
EXPO_PUBLIC_GATEWAY_URL=http://localhost:8080

# Keycloak OIDC configuration
EXPO_PUBLIC_KC_URL=http://localhost:8180
EXPO_PUBLIC_KC_REALM=ble

# ADR-020 GlitchTip error tracking — leave EMPTY to disable (dormant code path).
# Set ONLY after Privacy→Legal sign-off
# (terrio-platform-docs/06_operations/legal-review-log.md entry 2026-05-27).
EXPO_PUBLIC_SENTRY_DSN=
