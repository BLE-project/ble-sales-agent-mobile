{
  "cli": { "version": ">= 12.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "http://10.0.2.2:8080",
        "EXPO_PUBLIC_KC_URL": "http://10.0.2.2:8180",
        "EXPO_PUBLIC_KC_REALM": "ble"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "https://api.ble-platform.com",
        "EXPO_PUBLIC_KC_URL": "https://auth.ble-platform.com",
        "EXPO_PUBLIC_KC_REALM": "ble"
      }
    },
    "production": {
      "android": { "buildType": "app-bundle" },
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "https://api.ble-platform.com",
        "EXPO_PUBLIC_KC_URL": "https://auth.ble-platform.com",
        "EXPO_PUBLIC_KC_REALM": "ble"
      }
    }
  }
}
