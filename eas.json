{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "http://10.0.2.2:8082",
        "EXPO_PUBLIC_KC_URL": "http://10.0.2.2:8180",
        "EXPO_PUBLIC_KC_REALM": "ble"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "https://api.terrio.it",
        "EXPO_PUBLIC_KC_URL": "https://auth.terrio.it",
        "EXPO_PUBLIC_KC_REALM": "ble"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "https://api.terrio.it",
        "EXPO_PUBLIC_KC_URL": "https://auth.terrio.it",
        "EXPO_PUBLIC_KC_REALM": "ble"
      }
    },
    "previewLocal": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "http://127.0.0.1:8080",
        "EXPO_PUBLIC_KC_URL": "http://127.0.0.1:8180",
        "EXPO_PUBLIC_KC_REALM": "ble",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "previewStaging": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_GATEWAY_URL": "TODO_STAGING_GATEWAY_URL_derive_after_infra-gcp_apply",
        "EXPO_PUBLIC_KC_URL": "TODO_STAGING_KC_URL_derive_after_infra-gcp_apply",
        "EXPO_PUBLIC_KC_REALM": "ble",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    }
  }
}
