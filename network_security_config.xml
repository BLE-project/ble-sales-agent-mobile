<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Config for Terrio mobile apps (Android targetSdkVersion>=28).
  Allows cleartext HTTP traffic for local dev backends only.

  Production builds (profile preview/production) point to https://api.terrio.it
  which uses TLS — this config does NOT weaken production security.
-->
<network-security-config>
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="true">localhost</domain>
    <domain includeSubdomains="true">127.0.0.1</domain>
    <domain includeSubdomains="true">10.0.2.2</domain>
    <domain includeSubdomains="true">192.168.1.135</domain>
    <domain includeSubdomains="true">192.168.1.203</domain>
    <domain includeSubdomains="true">api.ble-platform.local</domain>
  </domain-config>
  <base-config cleartextTrafficPermitted="false">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>
</network-security-config>
